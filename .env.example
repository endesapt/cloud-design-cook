DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iaas_demo?schema=public"
JWT_SECRET="change-this-super-secret-string"
JWT_EXPIRES_IN="7d"
PROVISION_MODE="docker"
MOCK_FAIL_RATE="0.05"
SECURITY_DEMO_FREEZE="false"
DOCKER_VM_IMAGE="alpine:3.20"
DOCKER_MIN_CPUS="0.10"
DOCKER_MIN_MEMORY_MB="64"
DOCKER_PIDS_LIMIT="64"
DOCKER_COMMAND_TIMEOUT_MS="120000"
DOCKER_FALLBACK_TO_MOCK="true"
